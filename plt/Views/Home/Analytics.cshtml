@model plt.Models.ViewModel.DashboardViewModel
@{
    ViewData["Title"] = "Аналитика";
}

<section class="analytics-page">
    <div class="page-hero compact">
        <div>
            <span class="eyebrow">AI-аналитика</span>
            <h1>Риск оттока учеников</h1>
            <p>ORLtrack рассчитывает риск ухода по активности ученика, а затем формирует текстовое объяснение через российскую нейросеть.</p>
        </div>
        <div class="page-hero-side">
            <div class="mini-stat">
                <span>AI-провайдер</span>
                <strong>@(Model.IsRussianAiConfigured ? Model.AiProviderName : "Локальный fallback")</strong>
            </div>
            <div class="mini-stat">
                <span>Учеников в риске</span>
                <strong>@Model.Students.Count(x => x.ChurnRiskScore >= 40)</strong>
            </div>
        </div>
    </div>

    <section class="panel ai-insights-panel">
        <div class="panel-heading">
            <span>Нейросеть</span>
            <h2>Выводы по самым рискованным ученикам</h2>
        </div>

        @if (Model.AiInsights.Any())
        {
            <div class="ai-insights-grid">
                @foreach (var insight in Model.AiInsights)
                {
                    <article class="ai-insight-card">
                        <div class="ai-insight-top">
                            <div>
                                <strong>@insight.StudentName</strong>
                                <small>@insight.Provider</small>
                            </div>
                            <div class="risk-pill @GetRiskClass(insight.RiskLevel)">
                                <span>@insight.RiskLevel</span>
                                <strong>@insight.RiskScore%</strong>
                            </div>
                        </div>
                        <p>@insight.Summary</p>
                        <div class="ai-recommendation">
                            <span>Рекомендация</span>
                            <strong>@insight.Recommendation</strong>
                        </div>
                    </article>
                }
            </div>
        }
        else
        {
            <p class="panel-empty">Для AI-анализа пока недостаточно данных по ученикам.</p>
        }
    </section>

    <div class="analytics-grid">
        <section class="panel panel-dark">
            <div class="panel-heading">
                <span>Лидеры</span>
                <h2>Топ учеников по выручке</h2>
            </div>

            @if (Model.TopStudents.Any())
            {
                <div class="analytics-student-list">
                    @foreach (var student in Model.TopStudents)
                    {
                        <article class="analytics-student-item">
                            <div class="student-avatar">@student.Initials</div>
                            <div class="analytics-student-copy">
                                <strong>@student.FullName</strong>
                                <span>Занятий: @student.LessonsAttendedCount</span>
                            </div>
                            <div class="analytics-student-value">
                                <small>Доход</small>
                                <strong>@student.TotalCharged.ToString("N2")</strong>
                            </div>
                        </article>
                    }
                </div>
            }
            else
            {
                <p class="panel-empty">Пока нет данных для аналитики.</p>
            }
        </section>

        <section class="panel">
            <div class="panel-heading">
                <span>Риски</span>
                <h2>Кому нужно внимание</h2>
            </div>

            @if (Model.Students.Any())
            {
                <div class="analytics-warning-list">
                    @foreach (var student in Model.Students.OrderByDescending(x => x.ChurnRiskScore).Take(6))
                    {
                        <article class="warning-row">
                            <div>
                                <strong>@student.FullName</strong>
                                <small>@string.Join(", ", student.RiskSignals.Take(2))</small>
                            </div>
                            <div class="warning-row-values">
                                <span>@student.ChurnRiskScore%</span>
                                <small>@student.ChurnRiskLevel риск</small>
                            </div>
                        </article>
                    }
                </div>
            }
            else
            {
                <p class="panel-empty">Пока нет учеников для оценки.</p>
            }
        </section>

        <section class="panel analytics-summary">
            <div class="panel-heading">
                <span>Итоги</span>
                <h2>Сводка по кабинету</h2>
            </div>

            <div class="summary-grid">
                <div class="summary-card">
                    <span>Доход за всё время</span>
                    <strong>@Model.TotalRevenue.ToString("N2")</strong>
                </div>
                <div class="summary-card">
                    <span>Доход за месяц</span>
                    <strong>@Model.MonthlyRevenue.ToString("N2")</strong>
                </div>
                <div class="summary-card">
                    <span>Всего занятий</span>
                    <strong>@Model.TotalLessons</strong>
                </div>
                <div class="summary-card">
                    <span>Средняя ставка</span>
                    <strong>@Model.AverageLessonRate.ToString("N2")</strong>
                </div>
            </div>
        </section>
    </div>
</section>

@functions {
    private string GetRiskClass(string riskLevel) => riskLevel switch
    {
        "Высокий" => "risk-high",
        "Средний" => "risk-medium",
        _ => "risk-low"
    };
}
