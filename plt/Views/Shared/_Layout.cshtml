<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ORLtrack</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Sora:wght@600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <div class="app-backdrop"></div>

    <div class="toast-container">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="toast toast-success">
                <span>@TempData["SuccessMessage"]</span>
                <button class="btn-close" type="button">&times;</button>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="toast toast-error">
                <span>@TempData["ErrorMessage"]</span>
                <button class="btn-close" type="button">&times;</button>
            </div>
        }

        @if (TempData["InfoMessage"] != null)
        {
            <div class="toast toast-info">
                <span>@TempData["InfoMessage"]</span>
                <button class="btn-close" type="button">&times;</button>
            </div>
        }
    </div>

    <header class="site-header">
        <div class="container header-container">
            <a class="brand" asp-controller="Home" asp-action="Index">
                <span class="brand-badge">ORL</span>
                <span class="brand-text">
                    <strong>ORLtrack</strong>
                    <small>Ученики, баланс и занятия</small>
                </span>
            </a>

            <nav class="nav-menu">
                <a asp-controller="Home" asp-action="Index">Обзор</a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="Home" asp-action="Students">Ученики</a>
                    <a asp-controller="Home" asp-action="Analytics">Аналитика</a>
                    <a asp-controller="Account" asp-action="Profile">Профиль</a>
                }
            </nav>

            <div class="header-actions">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    var avatarUrl = User.FindFirst("avatar_url")?.Value ?? Url.Content("~/Images/BaseAvatar.jpg");

                    <a asp-controller="Account" asp-action="Profile" class="user-chip">
                        <div class="user-chip-copy">
                            <strong>@(User.Identity?.Name ?? "Профиль")</strong>
                            <small>Личный кабинет</small>
                        </div>
                        <img src="@avatarUrl" alt="Аватар" class="avatar-img" />
                    </a>
                }
                else
                {
                    <a class="btn btn-ghost" asp-controller="Account" asp-action="Login">Войти</a>
                    <a class="btn" asp-controller="Account" asp-action="Register">Создать аккаунт</a>
                }
            </div>
        </div>
    </header>

    <main class="container page-content">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container footer-shell">
            <div>
                <strong>ORLtrack</strong>
                <p>Современная панель для преподавателя с удобным управлением учениками, уроками и оплатами.</p>
            </div>
            <div class="footer-meta">
                <span>Учет посещаемости</span>
                <span>Финансы и метрики</span>
            </div>
        </div>
    </footer>

    @RenderSection("Scripts", required: false)
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const toasts = document.querySelectorAll(".toast");

            toasts.forEach(toast => {
                toast.classList.add("show");

                setTimeout(() => {
                    toast.classList.remove("show");
                    setTimeout(() => toast.remove(), 350);
                }, 4200);

                const closeButton = toast.querySelector(".btn-close");
                if (closeButton) {
                    closeButton.addEventListener("click", () => {
                        toast.classList.remove("show");
                        setTimeout(() => toast.remove(), 350);
                    });
                }
            });
        });
    </script>
</body>
</html>
